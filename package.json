{
	"name": "@turystack/nestjs-social-auth",
	"private": false,
	"version": "0.0.5",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"test": "vitest run",
		"test:cov": "vitest run --coverage",
		"lint": "biome lint ./src",
		"format": "biome format --write ./src",
		"check": "biome check --write ./src"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/turystack/nestjs-social-auth.git"
	},
	"dependencies": {
		"jose": "^5.9.0"
	},
	"peerDependencies": {
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"reflect-metadata": "^0.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.2",
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/testing": "^11.0.0",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^2.1.0",
		"reflect-metadata": "^0.2.2",
		"tsc-alias": "^1.8.16",
		"typescript": "^5.5.0",
		"vitest": "^2.1.0"
	}
}
